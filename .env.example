# =============================================================================
# Expense Tracker — environment variables (demo template)
# =============================================================================
#
# Setup:
#   cp .env.example .env.local
#   # Edit .env.local with real values (never commit .env.local)
#
# Vercel production:
#   Project → Settings → Environment Variables
#   Copy everything under "Vercel / vercel dev" below (not SUPABASE_ANON_KEY
#   unless you have a specific reason — use SERVICE_ROLE on server only).
#
# Flutter (run / build):
#   ./scripts/run-ios.sh   reads .env.local automatically when present
#   Or export vars manually before running flutter.
#
# Local API:
#   vercel dev   # loads .env.local from repo root by default
#
# =============================================================================

# -----------------------------------------------------------------------------
# Vercel / vercel dev — serverless API (api/*.js)
# -----------------------------------------------------------------------------
# Required for AI categorization + monthly insight
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Required for JWT auth, /api/me, dev-activate-pro (when enforcing Pro)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Workshop: unlock Pro on server for a user_id (POST /api/dev-activate-pro)
DEV_PRO_SECRET=your-dev-pro-secret

# Optional DeepSeek overrides
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# Flutter — compile-time (--dart-define, from .env.local via scripts)
# -----------------------------------------------------------------------------
# Vercel deployment URL (no trailing slash)
API_BASE_URL=https://your-app.vercel.app

# Same Supabase project as above — anon key is safe in the app (RLS required)
# SUPABASE_URL is already set above; scripts reuse it for Flutter.
SUPABASE_ANON_KEY=your-supabase-anon-key

# Debug builds only: must match DEV_PRO_SECRET on Vercel for「开发：激活 Pro」
# DEV_PRO_SECRET is already set above; scripts pass it to Flutter in debug.

# -----------------------------------------------------------------------------
# Do NOT put these in the Flutter app
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY — server only
# DEEPSEEK_API_KEY — server only
